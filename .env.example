# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET=xxx
NEXTAUTH_URL=http://localhost:3000

# ---- Google OAuth -------------------------------------------
# Create credentials at: https://console.developers.google.com
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=xxx

# Sign in with Apple (App Store guideline 4.8 — required alongside Google login)
# APPLE_CLIENT_ID is the Services ID (e.g. com.example.clipper.web).
# APPLE_CLIENT_SECRET is a self-generated ES256 JWT signed with your Apple
# private key (Team ID + Key ID) — it expires after max 6 months; regenerate.
APPLE_CLIENT_ID=xxx
APPLE_CLIENT_SECRET=xxx

# ---- Email (SMTP) -------------------------------------------
# For local dev: use Mailtrap (https://mailtrap.io) or Ethereal (https://ethereal.email)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=xxx
SMTP_PASSWORD=xxx
EMAIL_FROM=Clipper <noreply@clipper.app>

# ---- Storage (DigitalOcean Spaces) --------------------------
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_BUCKET=your-bucket-name
DO_SPACES_REGION=sgp1
# Optional: CDN endpoint for faster public delivery (recommended for thumbnails/clips)
# DO_SPACES_CDN_ENDPOINT=https://your-bucket-name.sgp1.cdn.digitaloceanspaces.com

# ---- Database (Amazon RDS) ----------------------------------
# Credentials below are read directly by src/lib/db.ts via the PG* env vars.

# ---- App Config ---------------------------------------------
APP_URL=http://localhost:3000
NODE_ENV=development

PGHOST=xxx
PGDATABASE=xxx
PGPORT=5432
PG_USER = xxx
PG_PASSWORD = xxx

# ---- AI Video Pipeline -------------------------------------------------------

# Anthropic Claude (animation spec generation)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini (scene planning + script generation + captions)
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# OpenAI key kept for reference (no longer used for pipeline)
OPENAI_API_KEY=sk-...

# Google Veo 3.1 Lite (per-scene image-to-video generation, via the Gemini API)
# Defaults to GEMINI_API_KEY above; set VEO_API_KEY only to use a separate key.
VEO_API_KEY=
# Model id. Default: veo-3.1-lite-generate-preview (cost-effective, 720p/1080p)
VEO_MODEL_NAME=veo-3.1-lite-generate-preview
# Output resolution: 720p (default) or 1080p (1080p requires an 8s duration)
VEO_RESOLUTION=720p
# Fallback clip length in seconds (Veo accepts only 4, 6 or 8) when a scene has none
VEO_DURATION=8
# Fallback aspect ratio when a scene has none: 16:9 or 9:16 (Veo's only options)
VEO_ASPECT_RATIO=9:16
# Optional negative prompt applied to every generation
VEO_NEGATIVE_PROMPT=

# ElevenLabs TTS — pipeline voice engine
# Obtain at https://elevenlabs.io/app/settings/api-keys
# Key permissions needed: Text to Speech (Voices: Read optional, for tooling)
ELEVENLABS_API_KEY=xxx
# Voice for the marketing voice-over. Default: Sarah (free-tier premade)
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# eleven_v3 is the only ElevenLabs model that supports Thai
ELEVENLABS_TTS_MODEL=eleven_v3
# v3 stability: 0.0 = Creative (default), 0.5 = Natural, 1.0 = Robust
ELEVENLABS_STABILITY=0.0

# FFmpeg (video composition + subtitle burn-in)
# Leave blank to use system PATH. Set to absolute path if FFmpeg is not in PATH.
FFMPEG_PATH=
# Temporary directory for FFmpeg intermediate files (must be writable)
FFMPEG_TMP_DIR=/tmp/clipper

# ---- Social Media Publishing -------------------------------------------------

# YouTube Data API v3
# Create OAuth credentials at https://console.cloud.google.com/
# Use the offline refresh-token flow to obtain a long-lived refresh token.
YOUTUBE_CLIENT_ID=xxx
YOUTUBE_CLIENT_SECRET=xxx
YOUTUBE_REFRESH_TOKEN=xxx

# TikTok Content Posting API
# Register your app at https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=xxx
TIKTOK_ACCESS_TOKEN=xxx

# Instagram Graph API (requires Facebook Business Manager)
INSTAGRAM_ACCESS_TOKEN=xxx
INSTAGRAM_PAGE_ID=xxx

# Facebook Graph API (Page video upload)
FACEBOOK_PAGE_TOKEN=xxx
FACEBOOK_PAGE_ID=xxx

# Tvent internal API
TVENT_API_KEY=xxx
TVENT_API_URL=https://api.tvent.app
# ---- Payments: Stripe (PromptPay QR) ----------------------------------------
# Stripe PromptPay QR. Enable PromptPay in the Stripe Dashboard and register:
# https://your-domain.example/api/payments/stripe/webhook
# Subscribe the endpoint to payment_intent.succeeded.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Minutes a generated PromptPay QR stays payable:
PAYMENT_INTENT_TTL_MINUTES=30
# Google Maps browser coordinate picker
# Restrict this browser key to your RClipper domains and Maps JavaScript API.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# ---- Native mobile stores and push notifications ----------------------------
# App Store Server API key (Users and Access > Integrations > In-App Purchase)
APP_STORE_ISSUER_ID=
APP_STORE_KEY_ID=
APP_STORE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APP_STORE_BUNDLE_ID=com.rclipper.app

# Google Play Android Publisher service account with order/purchase access
GOOGLE_PLAY_CLIENT_EMAIL=
GOOGLE_PLAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GOOGLE_PLAY_PACKAGE_NAME=com.rclipper.app

# Firebase Cloud Messaging HTTP v1 service account
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Apple Push Notification service token key
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APNS_BUNDLE_ID=com.rclipper.app
# sandbox for development/TestFlight-style development builds; production for App Store
APNS_ENVIRONMENT=sandbox

# Optional: log per-query request-detail page timings on the server.
REQUEST_DETAIL_PERF_LOG=0
NEW_REQUEST_PERF_LOG=0
