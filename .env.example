# ---- Database (Amazon RDS) ----------------------------------
# Credentials below are read directly by src/lib/db.ts via the PG* env vars.

# ---- App Config ---------------------------------------------
APP_URL=http://localhost:3000
NODE_ENV=development

PGHOST=xxx
PGDATABASE=xxx
PGPORT=5432
PG_USER = xxx
PG_PASSWORD = xxx